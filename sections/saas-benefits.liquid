{%- style -%}
  .saas-benefits {
    padding: var(--space-12) 0 !important;
    background: var(--surface-0) !important;
  }
  .saas-benefits-container {
    border: 1px solid rgba(163, 230, 53, 0.15) !important;
    border-radius: 40px !important;
    padding: 80px !important;
    background: var(--surface-1) !important;
    text-align: center !important;
    max-width: 1200px !important;
    margin: 0 auto !important;
    box-shadow: 0 4px 40px rgba(0, 0, 0, 0.4) !important;
  }
  .saas-benefits .title {
    font-size: 36px !important;
    font-weight: 800 !important;
    letter-spacing: -0.03em !important;
    margin-bottom: 64px !important;
    color: var(--text-primary) !important;
  }
  .saas-benefits-grid {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 48px !important;
  }
  .saas-benefit-item {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
  }
  .saas-benefit-icon {
    width: 56px !important;
    height: 56px !important;
    background: rgba(163, 230, 53, 0.1) !important;
    border-radius: 16px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    margin-bottom: 24px !important;
    color: #a3e635 !important;
    border: 1px solid rgba(163, 230, 53, 0.2) !important;
  }
  .saas-benefit-title {
    font-size: 18px !important;
    font-weight: 700 !important;
    color: var(--text-primary) !important;
    margin-bottom: 12px !important;
  }
  .saas-benefit-text {
    font-size: 15px !important;
    color: var(--text-secondary) !important;
    line-height: 1.6 !important;
    margin: 0 !important;
  }
  @media screen and (max-width: 989px) {
    .saas-benefits-container {
      padding: 40px !important;
    }
    .saas-benefits-grid {
      grid-template-columns: 1fr !important;
      gap: 40px !important;
    }
  }
{%- endstyle -%}

<section class="saas-benefits">
  <div class="page-width">
    <div class="saas-benefits-container">
      <h2 class="title">Why merchants choose ESTS Delete Customer Account</h2>

      <div class="saas-benefits-grid">
        <div class="saas-benefit-item">
          <div class="saas-benefit-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          </div>
          <h3 class="saas-benefit-title">Customer Empowerment</h3>
          <p class="saas-benefit-text">While Shopify admins can already delete accounts, our app extends this power directly to customers — giving them full control over their own data.</p>
        </div>

        <div class="saas-benefit-item">
          <div class="saas-benefit-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
          </div>
          <h3 class="saas-benefit-title">Reduce Support Tickets</h3>
          <p class="saas-benefit-text">Automate account deletion requests completely — no more manual back-and-forth with customers asking to be removed from your store.</p>
        </div>

        <div class="saas-benefit-item">
          <div class="saas-benefit-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          </div>
          <h3 class="saas-benefit-title">Secure & Transparent</h3>
          <p class="saas-benefit-text">Every deletion is handled securely with a clear confirmation flow — protecting both the customer's data and your store's compliance posture.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SaaS Benefits",
  "tag": "section",
  "class": "section",
  "presets": [
    {
      "name": "SaaS Benefits"
    }
  ]
}
{% endschema %}
