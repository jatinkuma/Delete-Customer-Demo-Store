{%- style -%}
  .saas-showcase {
    padding: var(--space-12) 0 !important;
    background: var(--surface-0) !important;
  }
  .saas-showcase .collection__title {
    margin-bottom: 64px !important;
  }
  .saas-showcase .section-label {
    display: block;
    color: var(--color-brand-1) !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    margin-bottom: 16px !important;
  }
  .saas-showcase .title {
    font-size: 42px !important;
    font-weight: 800 !important;
    letter-spacing: -0.03em !important;
    color: var(--text-primary) !important;
  }
  .saas-showcase-grid {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 32px !important;
  }
  .saas-showcase-card {
    background: var(--surface-1) !important;
    border: 1px solid rgba(163, 230, 53, 0.1) !important;
    border-radius: 20px !important;
    padding: 0 !important;
    display: flex !important;
    flex-direction: column !important;
    overflow: hidden !important;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4) !important;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
    height: 100% !important;
  }
  .saas-showcase-card:hover {
    transform: translateY(-8px) !important;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(163, 230, 53, 0.2) !important;
    border-color: rgba(163, 230, 53, 0.25) !important;
  }
  .saas-showcase-image {
    height: 200px !important;
    background: var(--surface-2) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    position: relative !important;
    overflow: hidden !important;
    border-bottom: 1px solid rgba(163, 230, 53, 0.08) !important;
  }
  .saas-showcase-image img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    transition: transform 0.8s ease;
  }
  .saas-showcase-content {
    padding: 24px !important;
    text-align: left !important;
    flex-grow: 1 !important;
    display: flex !important;
    flex-direction: column !important;
  }
  .saas-showcase-title {
    font-size: 20px !important;
    font-weight: 700 !important;
    color: var(--text-primary) !important;
    margin-bottom: 12px !important;
  }
  .saas-showcase-text {
    font-size: 15px !important;
    color: var(--text-secondary) !important;
    line-height: 1.6 !important;
    margin-bottom: 20px !important;
    flex-grow: 1 !important;
  }
  .saas-showcase-link {
    color: #a3e635 !important;
    font-weight: 600 !important;
    font-size: 15px !important;
    text-decoration: none !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 8px !important;
  }
  .saas-showcase-link span {
    transition: transform 0.3s ease;
  }
  .saas-showcase-card:hover .saas-showcase-link span {
    transform: translateX(5px);
  }
  @media screen and (max-width: 989px) {
    .saas-showcase-grid {
      grid-template-columns: 1fr !important;
    }
  }
{%- endstyle -%}

<section class="saas-showcase">
  <div class="page-width">
    <div class="collection__title center">
      <span class="section-label">How It Works</span>
      <h2 class="title">A seamless experience for customers & admins</h2>
    </div>

    <div class="saas-showcase-grid">
      <div class="saas-showcase-card">
        <div class="saas-showcase-image">
          <div style="width:100%;height:100%;background:linear-gradient(135deg,#0f1a00,#1a2e00);display:flex;align-items:center;justify-content:center;">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#a3e635" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle><line x1="18" y1="8" x2="23" y2="13"></line><line x1="23" y1="8" x2="18" y2="13"></line></svg>
          </div>
        </div>
        <div class="saas-showcase-content">
          <h3 class="saas-showcase-title">Customer Initiates Deletion</h3>
          <p class="saas-showcase-text">The customer visits their account page and clicks the "Delete Account" button. A confirmation modal appears asking them to select a reason for leaving.</p>
          <span class="saas-showcase-link">Step 1 <span>→</span></span>
        </div>
      </div>

      <div class="saas-showcase-card">
        <div class="saas-showcase-image">
          <div style="width:100%;height:100%;background:linear-gradient(135deg,#0f1a00,#1a2e00);display:flex;align-items:center;justify-content:center;">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#a3e635" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
          </div>
        </div>
        <div class="saas-showcase-content">
          <h3 class="saas-showcase-title">Admin Gets Notified</h3>
          <p class="saas-showcase-text">The moment a deletion is confirmed, the store admin receives an automated notification — including the customer ID and the reason they provided.</p>
          <span class="saas-showcase-link">Step 2 <span>→</span></span>
        </div>
      </div>

      <div class="saas-showcase-card">
        <div class="saas-showcase-image">
          <div style="width:100%;height:100%;background:linear-gradient(135deg,#0f1a00,#1a2e00);display:flex;align-items:center;justify-content:center;">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#a3e635" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>
          </div>
        </div>
        <div class="saas-showcase-content">
          <h3 class="saas-showcase-title">Account Securely Removed</h3>
          <p class="saas-showcase-text">The account is deleted securely from Shopify. All customer data is handled in compliance with privacy regulations — no loose ends.</p>
          <span class="saas-showcase-link">Step 3 <span>→</span></span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SaaS Showcase",
  "tag": "section",
  "class": "section",
  "presets": [
    {
      "name": "SaaS Showcase"
    }
  ]
}
{% endschema %}
