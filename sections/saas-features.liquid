{%- style -%}
  .saas-features {
    padding: var(--space-12) 0 !important;
    background: var(--surface-0) !important;
  }
  .saas-features .collection__title {
    margin-bottom: 64px !important;
  }
  .saas-features .section-label {
    display: block;
    color: var(--color-brand-1) !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    margin-bottom: 16px !important;
  }
  .saas-features .title {
    font-size: 42px !important;
    font-weight: 800 !important;
    letter-spacing: -0.03em !important;
    color: var(--text-primary) !important;
  }
  .saas-features-grid {
    display: grid !important;
    grid-template-columns: repeat(4, 1fr) !important;
    gap: 32px !important;
  }
  .saas-feature-card {
    background: var(--surface-1) !important;
    border: 1px solid rgba(163, 230, 53, 0.12) !important;
    border-radius: 20px !important;
    padding: 32px !important;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4) !important;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
    text-align: left !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    height: 100% !important;
  }
  .saas-feature-card:hover {
    transform: translateY(-8px) !important;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(163, 230, 53, 0.2) !important;
    border-color: rgba(163, 230, 53, 0.3) !important;
  }
  .saas-feature-icon {
    width: 52px !important;
    height: 52px !important;
    background: rgba(163, 230, 53, 0.1) !important;
    border-radius: 14px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    margin-bottom: 24px !important;
    color: #a3e635 !important;
    flex-shrink: 0 !important;
    border: 1px solid rgba(163, 230, 53, 0.2) !important;
  }
  .saas-feature-title {
    font-size: 18px !important;
    font-weight: 700 !important;
    color: var(--text-primary) !important;
    margin-bottom: 12px !important;
  }
  .saas-feature-text {
    font-size: 15px !important;
    color: var(--text-secondary) !important;
    line-height: 1.6 !important;
    margin: 0 !important;
    flex-grow: 1 !important;
  }
  @media screen and (max-width: 989px) {
    .saas-features-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media screen and (max-width: 749px) {
    .saas-features-grid {
      grid-template-columns: 1fr !important;
    }
  }
{%- endstyle -%}

<section class="saas-features">
  <div class="page-width">
    <div class="collection__title center">
      <span class="section-label">App Features</span>
      <h2 class="title">Everything ESTS Delete Customer Account offers</h2>
    </div>

    <div class="saas-features-grid">
      <div class="saas-feature-card">
        <div class="saas-feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
        </div>
        <h3 class="saas-feature-title">Easy Deletion Process</h3>
        <p class="saas-feature-text">Customers can delete their Shopify account in just one click — directly from their account page. No admin involvement, no friction.</p>
      </div>

      <div class="saas-feature-card">
        <div class="saas-feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
        </div>
        <h3 class="saas-feature-title">Automated Notifications</h3>
        <p class="saas-feature-text">Store admins are automatically notified whenever a customer deletes their account — keeping you informed without manual checks.</p>
      </div>

      <div class="saas-feature-card">
        <div class="saas-feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        </div>
        <h3 class="saas-feature-title">Data Protection Focus</h3>
        <p class="saas-feature-text">Secure and transparent account removal process that prioritizes customer data privacy and keeps your store GDPR compliant.</p>
      </div>

      <div class="saas-feature-card">
        <div class="saas-feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
        </div>
        <h3 class="saas-feature-title">Multilingual Support</h3>
        <p class="saas-feature-text">Gold plan members get multilingual access so customers worldwide can use the app in their preferred language.</p>
      </div>
    </div>
  </div>
</section>

