{%- style -%}
  .app-storyboard {
    --story-accent: {{ section.settings.accent_color }};
    --story-accent-deep: #433879;
    --story-accent-soft: rgba(84, 74, 147, 0.08);
    --story-ink: #202127;
    --story-muted: #60646f;
    --story-line: rgba(32, 33, 39, 0.08);
    --story-surface: #ffffff;
    --story-surface-alt: #f7f7fb;
    --story-shadow: 0 24px 70px rgba(33, 24, 78, 0.12);
    font-family: 'Manrope', sans-serif;
    color: var(--story-ink);
    background:
      radial-gradient(circle at top left, rgba(84, 74, 147, 0.12), transparent 32%),
      linear-gradient(180deg, #ffffff 0%, #fcfcfe 100%);
  }

  .app-storyboard .page-width {
    max-width: 138rem;
  }

  .app-storyboard__hero {
    padding: 16rem 0 8rem;
  }

  .app-storyboard__hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 4.8rem;
    align-items: center;
  }

  .app-storyboard__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1.5rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(84, 74, 147, 0.15);
    color: var(--story-accent-deep);
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    box-shadow: 0 10px 30px rgba(84, 74, 147, 0.08);
  }

  .app-storyboard__eyebrow::before {
    content: '';
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
    background: var(--story-accent);
  }

  .app-storyboard__hero-title {
    margin: 2.2rem 0 2rem;
    font-size: clamp(4.4rem, 5.4vw, 7.2rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
    font-weight: 800;
    color: var(--story-ink);
  }

  .app-storyboard__hero-title strong {
    color: var(--story-accent);
    font-weight: 800;
  }

  .app-storyboard__hero-text {
    margin: 0 0 3rem;
    max-width: 58rem;
    font-size: 1.95rem;
    line-height: 1.7;
    color: var(--story-muted);
  }

  .app-storyboard__hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem;
    margin-bottom: 3.2rem;
  }

  .app-storyboard__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 5.4rem;
    padding: 0 2.2rem;
    border-radius: 999px;
    font-size: 1.55rem;
    font-weight: 800;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
  }

  .app-storyboard__button:hover {
    transform: translateY(-2px);
  }

  .app-storyboard__button--primary {
    color: #ffffff;
    background: linear-gradient(135deg, var(--story-accent), #6d5dbb);
    box-shadow: 0 18px 36px rgba(84, 74, 147, 0.22);
  }

  .app-storyboard__button--secondary {
    color: var(--story-ink);
    background: #ffffff;
    border: 1px solid var(--story-line);
  }

  .app-storyboard__hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.6rem;
  }

  .app-storyboard__stat {
    padding: 1.8rem;
    border-radius: 2rem;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(84, 74, 147, 0.1);
    box-shadow: 0 14px 30px rgba(15, 17, 34, 0.04);
  }

  .app-storyboard__stat-value {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 2.6rem;
    font-weight: 800;
    letter-spacing: -0.05em;
  }

  .app-storyboard__stat-label {
    display: block;
    font-size: 1.4rem;
    line-height: 1.5;
    color: var(--story-muted);
  }

  .app-storyboard__hero-card {
    position: relative;
    padding: 2rem;
    border-radius: 3rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(249, 249, 253, 0.98));
    border: 1px solid rgba(84, 74, 147, 0.1);
    box-shadow: var(--story-shadow);
  }

  .app-storyboard__hero-card::before {
    content: '';
    position: absolute;
    inset: 2rem auto auto 2rem;
    width: 14rem;
    height: 14rem;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(84, 74, 147, 0.18) 0%, transparent 68%);
    pointer-events: none;
  }

  .app-storyboard__appbar {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 1.4rem;
    margin-bottom: 1.8rem;
  }

  .app-storyboard__brand-mark {
    width: 5.4rem;
    height: 5.4rem;
    border-radius: 50%;
    background: #2a2a2f;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    color: #ffffff;
    flex-shrink: 0;
  }

  .app-storyboard__brand-mark img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .app-storyboard__brand-mark svg {
    width: 2.6rem;
    height: 2.6rem;
  }

  .app-storyboard__app-name {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  .app-storyboard__app-meta {
    display: block;
    margin-top: 0.2rem;
    font-size: 1.35rem;
    color: var(--story-muted);
  }

  .app-storyboard__hero-screen {
    position: relative;
    z-index: 1;
    overflow: hidden;
    border-radius: 2rem;
    background: #ffffff;
    border: 1px solid rgba(15, 15, 15, 0.06);
    min-height: 28rem;
  }

  .app-storyboard__mock-screen {
    min-height: 28rem;
    padding: 2rem;
    background: linear-gradient(180deg, rgba(247, 247, 251, 0.92), #ffffff 24%);
  }

  .app-storyboard__mock-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.8rem;
  }

  .app-storyboard__mock-dots {
    display: flex;
    gap: 0.6rem;
  }

  .app-storyboard__mock-dots span {
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 50%;
    background: #d7d9e5;
  }

  .app-storyboard__mock-chip {
    padding: 0.8rem 1.2rem;
    border-radius: 999px;
    background: rgba(84, 74, 147, 0.08);
    color: var(--story-accent-deep);
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .app-storyboard__mock-layout {
    display: grid;
    grid-template-columns: 2.1fr 1fr;
    gap: 1.6rem;
  }

  .app-storyboard__mock-card {
    border: 1px solid rgba(20, 22, 31, 0.08);
    border-radius: 1.8rem;
    background: #ffffff;
    box-shadow: 0 14px 28px rgba(15, 17, 34, 0.04);
  }

  .app-storyboard__mock-card--padded {
    padding: 1.6rem;
  }

  .app-storyboard__mock-title {
    height: 1.4rem;
    width: 36%;
    margin-bottom: 1.2rem;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(84, 74, 147, 0.18), rgba(84, 74, 147, 0.05));
  }

  .app-storyboard__mock-title--long {
    width: 62%;
  }

  .app-storyboard__mock-inputs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .app-storyboard__mock-field {
    height: 4.2rem;
    border-radius: 1.2rem;
    background: #f5f6fb;
    border: 1px solid rgba(20, 22, 31, 0.06);
  }

  .app-storyboard__mock-pill {
    width: 16rem;
    height: 3.6rem;
    margin-bottom: 1.4rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #2c2f36, #4e5190);
  }

  .app-storyboard__mock-table {
    display: grid;
    gap: 0.8rem;
  }

  .app-storyboard__mock-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 0.8fr 0.8fr 0.9fr;
    gap: 0.8rem;
  }

  .app-storyboard__mock-row span {
    height: 3.8rem;
    border-radius: 1rem;
    background: #f7f7fb;
    border: 1px solid rgba(20, 22, 31, 0.05);
  }

  .app-storyboard__mock-row--header span {
    height: 1.2rem;
    background: #e4e6f0;
    border: 0;
  }

  .app-storyboard__mock-side {
    display: grid;
    gap: 1.2rem;
  }

  .app-storyboard__mock-stat-card {
    padding: 1.6rem;
  }

  .app-storyboard__mock-stat {
    height: 4rem;
    width: 52%;
    margin-bottom: 0.8rem;
    border-radius: 1.2rem;
    background: linear-gradient(135deg, rgba(84, 74, 147, 0.2), rgba(84, 74, 147, 0.06));
  }

  .app-storyboard__mock-lines {
    display: grid;
    gap: 0.8rem;
  }

  .app-storyboard__mock-lines span {
    height: 1rem;
    border-radius: 999px;
    background: #e6e8f2;
  }

  .app-storyboard__mock-lines span:nth-child(2) {
    width: 84%;
  }

  .app-storyboard__mock-lines span:nth-child(3) {
    width: 66%;
  }

  .app-storyboard__mock-products {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 1.8rem;
    align-items: center;
  }

  .app-storyboard__mock-product-image {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    min-height: 22rem;
    padding: 1.8rem;
  }

  .app-storyboard__mock-board {
    border-radius: 3rem;
    background: linear-gradient(180deg, #1b1d22, #4741a3 120%);
  }

  .app-storyboard__mock-board:last-child {
    background: linear-gradient(180deg, #d6b8ff, #8b63d7 120%);
  }

  .app-storyboard__mock-product-copy {
    padding: 1.8rem;
  }

  .app-storyboard__mock-price {
    height: 1.8rem;
    width: 28%;
    margin: 1rem 0 1.8rem;
    border-radius: 999px;
    background: #dfe2f0;
  }

  .app-storyboard__mock-list {
    display: grid;
    gap: 1rem;
  }

  .app-storyboard__mock-list-item {
    display: grid;
    grid-template-columns: 1fr 6.4rem;
    gap: 1rem;
    align-items: center;
  }

  .app-storyboard__mock-list-item span:first-child {
    height: 1.2rem;
    border-radius: 999px;
    background: #e7e9f2;
  }

  .app-storyboard__mock-list-item span:last-child {
    height: 3.8rem;
    border-radius: 1rem;
    background: #f5f6fb;
    border: 1px solid rgba(20, 22, 31, 0.06);
  }

  .app-storyboard__mock-cta {
    width: 100%;
    height: 4.6rem;
    margin-top: 1.6rem;
    border-radius: 1.2rem;
    background: linear-gradient(135deg, #3f3f48, #6960b8);
  }

  .app-storyboard__mock-cart {
    padding: 1.8rem;
  }

  .app-storyboard__mock-cart-row {
    display: grid;
    grid-template-columns: 8rem 1.4fr 8rem 8rem;
    gap: 1.2rem;
    align-items: center;
    padding: 1.2rem 0;
    border-bottom: 1px solid rgba(20, 22, 31, 0.06);
  }

  .app-storyboard__mock-thumb {
    height: 7rem;
    border-radius: 1.2rem;
    background: linear-gradient(135deg, #80f6d5, #4d46a9);
  }

  .app-storyboard__mock-thumb--alt {
    background: linear-gradient(135deg, #1d2028, #b58cf4);
  }

  .app-storyboard__mock-qty,
  .app-storyboard__mock-total,
  .app-storyboard__mock-copyline {
    height: 1.2rem;
    border-radius: 999px;
    background: #e3e6f0;
  }

  .app-storyboard__mock-copyline:nth-child(2) {
    width: 70%;
  }

  .app-storyboard__mock-copyline:nth-child(3) {
    width: 42%;
  }

  .app-storyboard__mock-qty {
    height: 3.8rem;
    background: #f5f6fb;
    border: 1px solid rgba(20, 22, 31, 0.06);
  }

  .app-storyboard__mock-total {
    width: 70%;
    justify-self: end;
  }

  .app-storyboard__mock-summary {
    display: flex;
    justify-content: flex-end;
    padding-top: 1.6rem;
  }

  .app-storyboard__mock-summary-box {
    width: 26rem;
  }

  .app-storyboard__mock-summary-box .app-storyboard__mock-copyline {
    margin-left: auto;
    margin-bottom: 0.8rem;
  }

  .app-storyboard__mock-summary-box .app-storyboard__mock-copyline:first-child {
    width: 48%;
  }

  .app-storyboard__mock-summary-box .app-storyboard__mock-copyline:nth-child(2) {
    width: 62%;
  }

  .app-storyboard__mock-summary-box .app-storyboard__mock-cta {
    margin-top: 1.4rem;
  }

  .app-storyboard__hero-screen img,
  .app-storyboard__screen img {
    display: block;
    width: 100%;
    height: auto;
  }

  .app-storyboard__placeholder {
    min-height: 28rem;
    display: grid;
    place-items: center;
    padding: 3rem;
    text-align: center;
    color: var(--story-muted);
    background:
      linear-gradient(135deg, rgba(84, 74, 147, 0.08), rgba(84, 74, 147, 0.02)),
      #ffffff;
  }

  .app-storyboard__placeholder strong {
    display: block;
    margin-bottom: 0.8rem;
    font-size: 2rem;
    color: var(--story-ink);
  }

  .app-storyboard__feature-strip {
    padding-bottom: 8rem;
  }

  .app-storyboard__feature-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1.6rem;
  }

  .app-storyboard__feature {
    padding: 2.4rem 2rem;
    border-radius: 2rem;
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid var(--story-line);
    box-shadow: 0 14px 30px rgba(15, 17, 34, 0.04);
  }

  .app-storyboard__feature-title {
    margin: 0 0 0.8rem;
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .app-storyboard__feature-text {
    margin: 0;
    font-size: 1.45rem;
    line-height: 1.65;
    color: var(--story-muted);
  }

  .app-storyboard__section-head {
    padding-bottom: 2rem;
    text-align: center;
  }

  .app-storyboard__section-title {
    margin: 0 0 1.2rem;
    font-size: clamp(3.4rem, 4vw, 5rem);
    line-height: 1;
    letter-spacing: -0.05em;
    font-weight: 800;
  }

  .app-storyboard__section-text {
    max-width: 72rem;
    margin: 0 auto;
    font-size: 1.7rem;
    line-height: 1.7;
    color: var(--story-muted);
  }

  .app-storyboard__showcase {
    padding: 4rem 0 10rem;
  }

  .app-storyboard__row {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
    gap: 3rem;
    align-items: center;
    margin-top: 3rem;
    padding: 3rem;
    border-radius: 3.2rem;
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid rgba(84, 74, 147, 0.08);
    box-shadow: 0 22px 50px rgba(15, 17, 34, 0.05);
  }

  .app-storyboard__row--reverse {
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
  }

  .app-storyboard__row--reverse .app-storyboard__screen-col {
    order: 2;
  }

  .app-storyboard__screen-shell {
    padding: 1.6rem;
    border-radius: 2.4rem;
    background: linear-gradient(180deg, #5c4ea2 0%, #4b417f 100%);
    box-shadow: 0 24px 50px rgba(84, 74, 147, 0.22);
  }

  .app-storyboard__screen {
    overflow: hidden;
    border-radius: 1.8rem;
    background: #ffffff;
    min-height: 24rem;
  }

  .app-storyboard__copy-badge {
    display: inline-block;
    margin-bottom: 1.6rem;
    padding: 0.8rem 1.4rem;
    border-radius: 999px;
    background: var(--story-accent-soft);
    color: var(--story-accent-deep);
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .app-storyboard__copy-title {
    margin: 0 0 1.6rem;
    font-size: clamp(3.4rem, 4vw, 4.8rem);
    line-height: 1;
    letter-spacing: -0.05em;
    font-weight: 800;
    white-space: pre-line;
  }

  .app-storyboard__copy-label {
    margin: 0 0 1.8rem;
    font-size: 2rem;
    font-weight: 800;
    color: var(--story-ink);
  }

  .app-storyboard__points {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.2rem;
  }

  .app-storyboard__point {
    display: grid;
    grid-template-columns: 3.2rem minmax(0, 1fr);
    gap: 1.2rem;
    align-items: start;
    font-size: 1.7rem;
    line-height: 1.7;
    color: var(--story-muted);
  }

  .app-storyboard__point-index {
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--story-accent);
    color: #ffffff;
    font-size: 1.35rem;
    font-weight: 800;
  }

  .app-storyboard__cta {
    padding: 0 0 11rem;
  }

  .app-storyboard__cta-box {
    position: relative;
    overflow: hidden;
    padding: 5rem;
    border-radius: 3.2rem;
    background: linear-gradient(135deg, #4f4691 0%, #6356ae 50%, #796ad0 100%);
    color: #ffffff;
    box-shadow: 0 30px 60px rgba(63, 52, 120, 0.25);
  }

  .app-storyboard__cta-box::after {
    content: '';
    position: absolute;
    right: -6rem;
    top: -6rem;
    width: 20rem;
    height: 20rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
  }

  .app-storyboard__cta-title {
    position: relative;
    z-index: 1;
    margin: 0 0 1.2rem;
    font-size: clamp(3.2rem, 4vw, 4.8rem);
    line-height: 1;
    letter-spacing: -0.05em;
    font-weight: 800;
  }

  .app-storyboard__cta-text {
    position: relative;
    z-index: 1;
    max-width: 66rem;
    margin: 0 0 2.6rem;
    font-size: 1.7rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.84);
  }

  .app-storyboard__cta .app-storyboard__button--secondary {
    border-color: rgba(255, 255, 255, 0.18);
  }

  @media screen and (max-width: 1199px) {
    .app-storyboard__feature-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 989px) {
    .app-storyboard__hero {
      padding-top: 13rem;
    }

    .app-storyboard__hero-grid,
    .app-storyboard__row,
    .app-storyboard__row--reverse {
      grid-template-columns: 1fr;
    }

    .app-storyboard__row--reverse .app-storyboard__screen-col {
      order: 0;
    }

    .app-storyboard__hero-stats,
    .app-storyboard__feature-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .app-storyboard__mock-layout,
    .app-storyboard__mock-products {
      grid-template-columns: 1fr;
    }

    .app-storyboard__mock-row {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .app-storyboard__mock-cart-row {
      grid-template-columns: 6rem 1fr 6rem;
    }

    .app-storyboard__mock-total {
      display: none;
    }

    .app-storyboard__row,
    .app-storyboard__cta-box {
      padding: 2.4rem;
    }
  }

  @media screen and (max-width: 749px) {
    .app-storyboard__hero {
      padding-top: 12rem;
      padding-bottom: 5rem;
    }

    .app-storyboard__hero-stats,
    .app-storyboard__feature-grid {
      grid-template-columns: 1fr;
    }

    .app-storyboard__hero-title {
      font-size: clamp(3.8rem, 10vw, 5.4rem);
    }

    .app-storyboard__hero-text,
    .app-storyboard__section-text,
    .app-storyboard__cta-text,
    .app-storyboard__point {
      font-size: 1.55rem;
    }

    .app-storyboard__copy-title {
      font-size: clamp(2.8rem, 9vw, 4rem);
    }

    .app-storyboard__row {
      margin-top: 2rem;
    }
  }
{%- endstyle -%}

{%- assign hero_block = section.blocks.first -%}
{%- capture app_storyboard_mock_admin -%}
  <div class="app-storyboard__mock-screen">
    <div class="app-storyboard__mock-topbar">
      <div class="app-storyboard__mock-dots"><span></span><span></span><span></span></div>
