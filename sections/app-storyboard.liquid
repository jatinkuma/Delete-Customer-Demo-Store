<section class="app-storyboard">
  <div class="page-width app-storyboard__hero">
    <div class="app-storyboard__hero-grid">
      <div>
        <span class="app-storyboard__eyebrow">Shopify App — Account Management</span>
        <h1 class="app-storyboard__hero-title">
          Give customers <strong>full control</strong> over their account deletion.
        </h1>
        <p class="app-storyboard__hero-text">{{ section.settings.app_description }}</p>

        <div class="app-storyboard__hero-actions">
          <a class="app-storyboard__button app-storyboard__button--primary" href="{{ section.settings.app_url }}">View on Shopify App Store</a>
          <a class="app-storyboard__button app-storyboard__button--secondary" href="#AppStoryboardShowcase">See How It Works</a>
        </div>

        <div class="app-storyboard__hero-stats">
          <div class="app-storyboard__stat">
            <span class="app-storyboard__stat-value" style="color:#a3e635;">1-Click</span>
            <span class="app-storyboard__stat-label">Customers can delete their account instantly with a single click</span>
          </div>
          <div class="app-storyboard__stat">
            <span class="app-storyboard__stat-value" style="color:#a3e635;">Auto Notify</span>
            <span class="app-storyboard__stat-label">Admins are automatically notified when an account is deleted</span>
          </div>
          <div class="app-storyboard__stat">
            <span class="app-storyboard__stat-value" style="color:#a3e635;">GDPR Ready</span>
            <span class="app-storyboard__stat-label">Secure, transparent data removal that keeps your store compliant</span>
          </div>
        </div>
      </div>

      <div class="app-storyboard__hero-card">
        <div class="app-storyboard__appbar">
          <span class="app-storyboard__brand-mark">
            {%- if section.settings.app_logo != blank -%}
              {{ section.settings.app_logo | image_url: width: 140 | image_tag: loading: 'lazy', widths: '70, 100, 140' }}
            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="6" r="2" fill="currentColor"/>
                <circle cx="6" cy="10" r="2" fill="currentColor"/>
                <circle cx="18" cy="10" r="2" fill="currentColor"/>
                <path d="M12 8v5M6 12l6 3 6-3M8 18h8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            {%- endif -%}
          </span>
          <div>
            <span class="app-storyboard__app-name">{{ section.settings.app_name }}</span>
            <span class="app-storyboard__app-meta">One-click account deletion for Shopify customers</span>
          </div>
        </div>

        <div class="app-storyboard__hero-screen">
          {%- if hero_block != blank and hero_block.settings.image != blank -%}
            {{ hero_block.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '550, 750, 1100, 1500, 1600' }}
          {%- else -%}
            {{ app_storyboard_mock_admin }}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  <div class="page-width app-storyboard__feature-strip">
    <div class="app-storyboard__feature-grid">
      <article class="app-storyboard__feature">
        <h3 class="app-storyboard__feature-title">Easy Deletion Process</h3>
        <p class="app-storyboard__feature-text">Customers can delete their account in one click directly from their account page — no admin involvement needed.</p>
      </article>
      <article class="app-storyboard__feature">
        <h3 class="app-storyboard__feature-title">Automated Notifications</h3>
        <p class="app-storyboard__feature-text">Store admins receive instant notifications whenever a customer initiates account deletion.</p>
      </article>
      <article class="app-storyboard__feature">
        <h3 class="app-storyboard__feature-title">Data Protection Focus</h3>
        <p class="app-storyboard__feature-text">Secure and transparent account removal process that prioritizes customer data privacy and GDPR compliance.</p>
      </article>
      <article class="app-storyboard__feature">
        <h3 class="app-storyboard__feature-title">Deletion Reason Tracking</h3>
        <p class="app-storyboard__feature-text">Customers can optionally share why they're leaving, giving merchants valuable feedback to improve retention.</p>
      </article>
      <article class="app-storyboard__feature">
        <h3 class="app-storyboard__feature-title">Multilingual Support</h3>
        <p class="app-storyboard__feature-text">Gold plan members get multilingual access so customers worldwide can use the app in their preferred language.</p>
      </article>
    </div>
  </div>

  <div id="AppStoryboardShowcase" class="page-width app-storyboard__showcase">
    <div class="app-storyboard__section-head">
      <h2 class="app-storyboard__section-title">See the app in action</h2>
      <p class="app-storyboard__section-text">
        A complete walkthrough of how ESTS Delete Customer Account works — from the customer-facing deletion flow to the admin dashboard.
      </p>
    </div>

    {%- for block in section.blocks -%}
      {%- assign bullet_items = block.settings.points | newline_to_br | split: '<br />' -%}
      <article class="app-storyboard__row {% if block.settings.media_position == 'left' %}app-storyboard__row--reverse{% endif %}" {{ block.shopify_attributes }}>
        <div class="app-storyboard__screen-col">
          <div class="app-storyboard__screen-shell">
            <div class="app-storyboard__screen">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '550, 750, 1100, 1500, 1600' }}
              {%- else -%}
                {%- assign title_handle = block.settings.title | downcase -%}
                {%- assign eyebrow_handle = block.settings.eyebrow | downcase -%}
                {%- if title_handle contains 'deleted customers' or title_handle contains 'list' -%}
                  {{ app_storyboard_mock_storefront }}
                {%- elsif title_handle contains 'configure' or title_handle contains 'config' or eyebrow_handle contains 'configuration' -%}
                  {{ app_storyboard_mock_cart }}
                {%- elsif title_handle contains 'multilingual' or title_handle contains 'language' or eyebrow_handle contains 'multilingual' -%}
                  {{ app_storyboard_mock_multilingual }}
                {%- else -%}
                  {{ app_storyboard_mock_admin }}
                {%- endif -%}
              {%- endif -%}
            </div>
          </div>
        </div>

        <div>
          {%- if block.settings.eyebrow != blank -%}
            <span class="app-storyboard__copy-badge">{{ block.settings.eyebrow }}</span>
          {%- endif -%}
          <h3 class="app-storyboard__copy-title">{{ block.settings.title }}</h3>
          {%- if block.settings.label != blank -%}
            <p class="app-storyboard__copy-label">{{ block.settings.label }}</p>
          {%- endif -%}

          {%- if bullet_items.size > 0 -%}
            <ol class="app-storyboard__points">
              {%- for item in bullet_items -%}
                {%- assign clean_item = item | strip -%}
                {%- if clean_item != blank -%}
                  <li class="app-storyboard__point">
                    <span class="app-storyboard__point-index">{{ forloop.index }}</span>
                    <span>{{ clean_item }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ol>
          {%- endif -%}
        </div>
      </article>
    {%- endfor -%}
  </div>

  <div class="page-width app-storyboard__cta">
    <div class="app-storyboard__cta-box">
      <h2 class="app-storyboard__cta-title">Empower your customers with account control.</h2>
      <p class="app-storyboard__cta-text">
        ESTS Delete Customer Account gives Shopify customers the freedom to delete their own accounts securely — reducing support tickets and building trust.
      </p>
      <div class="app-storyboard__hero-actions">
        <a class="app-storyboard__button app-storyboard__button--primary" href="{{ section.settings.app_url }}">Install on Shopify</a>
        <a class="app-storyboard__button app-storyboard__button--secondary" href="#MainContent">Back to Top</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "App storyboard",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
