    </div>
    <div class="app-storyboard__mock-layout">
      <div class="app-storyboard__mock-card app-storyboard__mock-card--padded">
        <div class="app-storyboard__mock-title app-storyboard__mock-title--long"></div>
        <div class="app-storyboard__mock-inputs">
          <div class="app-storyboard__mock-field"></div>
          <div class="app-storyboard__mock-field"></div>
        </div>
        <div class="app-storyboard__mock-pill"></div>
        <div class="app-storyboard__mock-table">
          <div class="app-storyboard__mock-row app-storyboard__mock-row--header"><span></span><span></span><span></span><span></span><span></span></div>
          <div class="app-storyboard__mock-row"><span></span><span></span><span></span><span></span><span></span></div>
          <div class="app-storyboard__mock-row"><span></span><span></span><span></span><span></span><span></span></div>
          <div class="app-storyboard__mock-row"><span></span><span></span><span></span><span></span><span></span></div>
        </div>
      </div>
      <div class="app-storyboard__mock-side">
        <div class="app-storyboard__mock-card app-storyboard__mock-stat-card">
          <div class="app-storyboard__mock-stat"></div>
          <div class="app-storyboard__mock-lines"><span></span><span></span><span></span></div>
        </div>
        <div class="app-storyboard__mock-card app-storyboard__mock-stat-card">
          <div class="app-storyboard__mock-stat"></div>
          <div class="app-storyboard__mock-lines"><span></span><span></span><span></span></div>
        </div>
      </div>
    </div>
  </div>
{%- endcapture -%}

{%- capture app_storyboard_mock_storefront -%}
  <div class="app-storyboard__mock-screen">
    <div class="app-storyboard__mock-topbar">
      <div class="app-storyboard__mock-dots"><span></span><span></span><span></span></div>
      <span class="app-storyboard__mock-chip">Storefront bundle</span>
    </div>
    <div class="app-storyboard__mock-card app-storyboard__mock-card--padded">
      <div class="app-storyboard__mock-products">
        <div class="app-storyboard__mock-product-image">
          <div class="app-storyboard__mock-board"></div>
          <div class="app-storyboard__mock-board"></div>
        </div>
        <div class="app-storyboard__mock-product-copy">
          <div class="app-storyboard__mock-title app-storyboard__mock-title--long"></div>
          <div class="app-storyboard__mock-price"></div>
          <div class="app-storyboard__mock-list">
            <div class="app-storyboard__mock-list-item"><span></span><span></span></div>
            <div class="app-storyboard__mock-list-item"><span></span><span></span></div>
            <div class="app-storyboard__mock-list-item"><span></span><span></span></div>
            <div class="app-storyboard__mock-list-item"><span></span><span></span></div>
          </div>
          <div class="app-storyboard__mock-cta"></div>
        </div>
      </div>
    </div>
  </div>
{%- endcapture -%}

{%- capture app_storyboard_mock_cart -%}
  <div class="app-storyboard__mock-screen">
    <div class="app-storyboard__mock-topbar">
      <div class="app-storyboard__mock-dots"><span></span><span></span><span></span></div>
      <span class="app-storyboard__mock-chip">Cart page</span>
    </div>
    <div class="app-storyboard__mock-card app-storyboard__mock-card--padded app-storyboard__mock-cart">
      <div class="app-storyboard__mock-cart-row">
        <div class="app-storyboard__mock-thumb"></div>
        <div>
          <div class="app-storyboard__mock-copyline"></div>
          <div class="app-storyboard__mock-copyline"></div>
          <div class="app-storyboard__mock-copyline"></div>
        </div>
        <div class="app-storyboard__mock-qty"></div>
        <div class="app-storyboard__mock-total"></div>
      </div>
      <div class="app-storyboard__mock-cart-row">
        <div class="app-storyboard__mock-thumb app-storyboard__mock-thumb--alt"></div>
        <div>
          <div class="app-storyboard__mock-copyline"></div>
          <div class="app-storyboard__mock-copyline"></div>
          <div class="app-storyboard__mock-copyline"></div>
        </div>
        <div class="app-storyboard__mock-qty"></div>
        <div class="app-storyboard__mock-total"></div>
      </div>
      <div class="app-storyboard__mock-summary">
        <div class="app-storyboard__mock-summary-box">
          <div class="app-storyboard__mock-copyline"></div>
          <div class="app-storyboard__mock-copyline"></div>
          <div class="app-storyboard__mock-cta"></div>
        </div>
      </div>
    </div>
  </div>
{%- endcapture -%}

<section class="app-storyboard">
  <div class="page-width app-storyboard__hero">
    <div class="app-storyboard__hero-grid">
      <div>
        <span class="app-storyboard__eyebrow">Shopify App Experience</span>
        <h1 class="app-storyboard__hero-title">
          Build <strong>smart bundles</strong> and grouped product flows that feel clean, fast, and conversion-ready.
        </h1>
        <p class="app-storyboard__hero-text">{{ section.settings.app_description }}</p>

        <div class="app-storyboard__hero-actions">
          <a class="app-storyboard__button app-storyboard__button--primary" href="{{ section.settings.app_url }}">View App Listing</a>
          <a class="app-storyboard__button app-storyboard__button--secondary" href="#AppStoryboardShowcase">Explore Screens</a>
        </div>

        <div class="app-storyboard__hero-stats">
          <div class="app-storyboard__stat">
            <span class="app-storyboard__stat-value">Custom</span>
            <span class="app-storyboard__stat-label">Product options for bundles, groups, and personalized selections</span>
          </div>
          <div class="app-storyboard__stat">
            <span class="app-storyboard__stat-value">Drag & Drop</span>
            <span class="app-storyboard__stat-label">Merchants can arrange products quickly with a simple backend flow</span>
          </div>
          <div class="app-storyboard__stat">
            <span class="app-storyboard__stat-value">Storefront Ready</span>
            <span class="app-storyboard__stat-label">Cleaner grouped layouts, quantity controls, and simpler add-to-cart journeys</span>
          </div>
        </div>
      </div>

      <div class="app-storyboard__hero-card">
        <div class="app-storyboard__appbar">
          <span class="app-storyboard__brand-mark">
            {%- if section.settings.app_logo != blank -%}
              {{ section.settings.app_logo | image_url: width: 140 | image_tag: loading: 'lazy', widths: '70, 100, 140' }}
            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="6" r="2" fill="currentColor"/>
                <circle cx="6" cy="10" r="2" fill="currentColor"/>
                <circle cx="18" cy="10" r="2" fill="currentColor"/>
                <path d="M12 8v5M6 12l6 3 6-3M8 18h8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            {%- endif -%}
          </span>
          <div>
            <span class="app-storyboard__app-name">{{ section.settings.app_name }}</span>
            <span class="app-storyboard__app-meta">Custom options, grouped products, and bundle setup for Shopify stores</span>
          </div>
        </div>

        <div class="app-storyboard__hero-screen">
          {%- if hero_block != blank and hero_block.settings.image != blank -%}
            {{ hero_block.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '550, 750, 1100, 1500, 1600' }}
          {%- else -%}
            {{ app_storyboard_mock_admin }}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  <div class="page-width app-storyboard__feature-strip">
    <div class="app-storyboard__feature-grid">
      <article class="app-storyboard__feature">
        <h3 class="app-storyboard__feature-title">Custom Product Options</h3>
        <p class="app-storyboard__feature-text">Flexible setup for product variants, groups, and bundle-driven selling experiences.</p>
      </article>
      <article class="app-storyboard__feature">
        <h3 class="app-storyboard__feature-title">Product Bundling</h3>
        <p class="app-storyboard__feature-text">Pair related items together and help merchants increase average order value with cleaner bundles.</p>
      </article>
      <article class="app-storyboard__feature">
        <h3 class="app-storyboard__feature-title">Grouped Products</h3>
        <p class="app-storyboard__feature-text">Show connected products in one structured view so shoppers can select combinations faster.</p>
      </article>
      <article class="app-storyboard__feature">
        <h3 class="app-storyboard__feature-title">Easy Drag-and-Drop Setup</h3>
        <p class="app-storyboard__feature-text">Merchants can reorder and organize products without getting stuck in a complicated admin flow.</p>
      </article>
      <article class="app-storyboard__feature">
        <h3 class="app-storyboard__feature-title">Customizable Display</h3>
        <p class="app-storyboard__feature-text">A presentation style that can adapt to different storefront needs while staying visually clean.</p>
      </article>
    </div>
  </div>

  <div id="AppStoryboardShowcase" class="page-width app-storyboard__showcase">
    <div class="app-storyboard__section-head">
      <h2 class="app-storyboard__section-title">Designed around real product workflows</h2>
      <p class="app-storyboard__section-text">
        Your provided screens are now presented as structured product stories, so the theme feels more premium and easier to scan for merchants reviewing the app.
      </p>
    </div>

    {%- for block in section.blocks -%}
      {%- assign bullet_items = block.settings.points | newline_to_br | split: '<br />' -%}
      <article class="app-storyboard__row {% if block.settings.media_position == 'left' %}app-storyboard__row--reverse{% endif %}" {{ block.shopify_attributes }}>
        <div class="app-storyboard__screen-col">
          <div class="app-storyboard__screen-shell">
            <div class="app-storyboard__screen">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '550, 750, 1100, 1500, 1600' }}
              {%- else -%}
                {%- assign title_handle = block.settings.title | downcase -%}
                {%- if title_handle contains 'cart' -%}
                  {{ app_storyboard_mock_cart }}
                {%- elsif title_handle contains 'storefront' -%}
                  {{ app_storyboard_mock_storefront }}
                {%- else -%}
                  {{ app_storyboard_mock_admin }}
                {%- endif -%}
              {%- endif -%}
            </div>
          </div>
        </div>

        <div>
          {%- if block.settings.eyebrow != blank -%}
            <span class="app-storyboard__copy-badge">{{ block.settings.eyebrow }}</span>
          {%- endif -%}
          <h3 class="app-storyboard__copy-title">{{ block.settings.title }}</h3>
          {%- if block.settings.label != blank -%}
            <p class="app-storyboard__copy-label">{{ block.settings.label }}</p>
          {%- endif -%}

          {%- if bullet_items.size > 0 -%}
            <ol class="app-storyboard__points">
              {%- for item in bullet_items -%}
                {%- assign clean_item = item | strip -%}
                {%- if clean_item != blank -%}
                  <li class="app-storyboard__point">
                    <span class="app-storyboard__point-index">{{ forloop.index }}</span>
                    <span>{{ clean_item }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ol>
          {%- endif -%}
        </div>
      </article>
    {%- endfor -%}
  </div>

  <div class="page-width app-storyboard__cta">
    <div class="app-storyboard__cta-box">
      <h2 class="app-storyboard__cta-title">Give merchants a cleaner way to sell bundled and grouped products.</h2>
      <p class="app-storyboard__cta-text">
        The layout now keeps your theme professional while still supporting the screenshot-driven storytelling you wanted for this app presentation.
      </p>
      <div class="app-storyboard__hero-actions">
        <a class="app-storyboard__button app-storyboard__button--primary" href="{{ section.settings.app_url }}">Open App Listing</a>
        <a class="app-storyboard__button app-storyboard__button--secondary" href="#MainContent">Back to Top</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "App storyboard",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "app_name",
      "label": "App name",
      "default": "ESTS Smart Product Bundler"
    },
    {
      "type": "url",
      "id": "app_url",
      "label": "App URL"
    },
    {
      "type": "textarea",
      "id": "app_description",
      "label": "App description",
      "default": "Easily create custom product options for your store with the Group & Bundle Product app. Create flexible bundle products, grouped selections, and personalized buying experiences with an easy drag-and-drop setup."
    },
    {
      "type": "image_picker",
      "id": "app_logo",
      "label": "App logo"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#544a93"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Showcase row",
      "settings": [
        {
          "type": "select",
          "id": "media_position",
          "label": "Screenshot position",
          "default": "right",
          "options": [
            { "value": "right", "label": "Right" },
            { "value": "left", "label": "Left" }
          ]
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Admin flow"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Bundle Product"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Subtitle",
          "default": "App Features:"
        },
        {
          "type": "textarea",
          "id": "points",
          "label": "Points",
          "default": "Add & customize product options easily.\nCreate either bundle or group products.\nSearch, add, delete, and reorder products.\nSet default selections.\nLet customers adjust quantities."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Screenshot"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "App storyboard"
    }
  ]
}
{% endschema %}
