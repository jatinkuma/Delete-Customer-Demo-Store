{%- style -%}
  .hero-premium {
    min-height: 100vh;
    background: var(--gradient-hero);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-12) var(--space-4);
  }

  .hero-premium__glow-orb {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.25;
    z-index: 1;
    pointer-events: none;
  }

  .hero-premium__glow-orb--purple {
    background: var(--color-brand-1);
    top: 10%;
    left: -10%;
  }

  .hero-premium__glow-orb--pink {
    background: var(--color-brand-3);
    bottom: 10%;
    right: -10%;
  }

  .hero-premium__content {
    position: relative;
    z-index: 2;
    max-width: 900px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 var(--space-4);
  }

  .hero-premium__eyebrow {
    display: inline-flex;
    padding: 8px 16px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-pill);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-brand-1);
    margin-bottom: var(--space-4);
    backdrop-filter: var(--glass-blur);
    animation: fadeInUp 0.7s ease both;
  }

  .hero-premium__headline {
    font-size: var(--text-hero);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-4);
    background: var(--text-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: fadeInUp 0.7s ease both 0.1s;
    word-wrap: break-word;
    overflow-wrap: break-word;
    hyphens: auto;
  }

  .hero-premium__subheading {
    font-size: 1.25rem;
    color: var(--text-secondary);
    max-width: 640px;
    margin-bottom: var(--space-6);
    line-height: 1.6;
    animation: fadeInUp 0.7s ease both 0.2s;
  }

  .hero-premium__actions {
    display: flex;
    gap: var(--space-4);
    animation: fadeInUp 0.7s ease both 0.3s;
  }

  .hero-premium__social-proof {
    margin-top: var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    animation: fadeInUp 0.7s ease both 0.4s;
  }

  .hero-premium__social-text {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
  }

  .hero-premium__social-logos {
    display: flex;
    gap: var(--space-6);
    opacity: 0.5;
    filter: grayscale(1);
  }

  @media screen and (max-width: 768px) {
    .hero-premium__content {
      padding: 0 var(--space-2);
    }
    
    .hero-premium__headline {
      font-size: 2.5rem;
      line-height: 1.2;
      padding: 0 var(--space-2);
    }
    
    .hero-premium__subheading {
      font-size: 1.125rem;
      max-width: 90%;
    }
  }

  @media screen and (max-width: 480px) {
    .hero-premium__content {
      padding: 0 var(--space-1);
    }
    
    .hero-premium__headline {
      font-size: 2rem;
      line-height: 1.3;
      padding: 0 var(--space-1);
    }
    
    .hero-premium__subheading {
      font-size: 1rem;
      max-width: 95%;
    }
  }
{%- endstyle -%}

<section class="hero-premium">
  <div class="hero-premium__glow-orb hero-premium__glow-orb--purple"></div>
  <div class="hero-premium__glow-orb hero-premium__glow-orb--pink"></div>

  <div class="hero-premium__content">
    {%- if section.settings.eyebrow != blank -%}
      <div class="hero-premium__eyebrow">
        {{ section.settings.eyebrow }}
      </div>
    {%- endif -%}

    <h1 class="hero-premium__headline">
      {{ section.settings.headline | default: 'The Future of Shopify Apps' }}
    </h1>

    <div class="hero-premium__subheading">
      {{ section.settings.subheading | default: 'Scale your storefront with our premium design system. Built for speed, high conversion, and developer experience.' }}
    </div>

    <div class="hero-premium__actions">
      <a href="{{ section.settings.primary_cta_link }}" class="btn--primary">
        {{ section.settings.primary_cta_label | default: 'Get Started' }}
      </a>
      <a href="{{ section.settings.secondary_cta_link }}" class="btn--ghost">
        {{ section.settings.secondary_cta_label | default: 'Book a Demo' }}
      </a>
    </div>

    <div class="hero-premium__social-proof">
      <span class="hero-premium__social-text">Trusted by Shopify merchants worldwide — secure, simple, one-click account deletion</span>
      <div class="hero-premium__social-logos">
        <!-- Shopify App Store badges can be added here -->
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Premium Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "ESTS — Shopify App"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Empower Your Customers with One-Click Account Deletion"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Enable secure account deletion directly from the customer's account page. Automated admin notifications, data protection focus, and a seamless one-click experience."
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary CTA Label",
      "default": "Install on Shopify"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Primary CTA Link"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary CTA Label",
      "default": "See How It Works"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary CTA Link"
    }
  ],
  "presets": [
    {
      "name": "Premium Hero"
    }
  ]
}
{% endschema %}
