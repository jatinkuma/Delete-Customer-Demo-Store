{%- style -%}
  .saas-cta {
    padding: var(--space-12) 0 !important;
    background: var(--surface-0) !important;
  }
  .saas-cta-container {
    background: linear-gradient(135deg, #0f1a00 0%, #1a2e00 50%, #0a1400 100%) !important;
    border: 1px solid rgba(163, 230, 53, 0.3) !important;
    border-radius: 40px !important;
    padding: 100px 40px !important;
    margin: 0 40px !important;
    text-align: center !important;
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(163, 230, 53, 0.08), 0 0 0 1px rgba(163, 230, 53, 0.05) !important;
  }
  .saas-cta-container::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, rgba(163, 230, 53, 0.06), transparent 60%);
    pointer-events: none;
  }
  .saas-cta-heading {
    color: #a3e635 !important;
    font-size: 56px !important;
    font-weight: 800 !important;
    letter-spacing: -0.04em !important;
    margin-bottom: 24px !important;
    line-height: 1.1 !important;
    position: relative;
    z-index: 2;
  }
  .saas-cta-text {
    color: rgba(240, 240, 240, 0.8) !important;
    font-size: 20px !important;
    max-width: 600px !important;
    margin: 0 auto 48px !important;
    line-height: 1.6 !important;
    position: relative;
    z-index: 2;
  }
  .button--cta {
    background: #a3e635 !important;
    color: #0a0a0a !important;
    border-radius: 9999px !important;
    padding: 20px 48px !important;
    font-weight: 700 !important;
    font-size: 18px !important;
    text-decoration: none !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 12px !important;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
    position: relative;
    z-index: 2;
    box-shadow: 0 8px 30px rgba(163, 230, 53, 0.3) !important;
  }
  .button--cta:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 16px 40px rgba(163, 230, 53, 0.45) !important;
    background: #bef264 !important;
  }
  @media screen and (max-width: 749px) {
    .saas-cta-container {
      margin: 0 20px !important;
      padding: 60px 24px !important;
    }
    .saas-cta-heading {
      font-size: 36px !important;
    }
  }
{%- endstyle -%}

<section class="saas-cta">
  <div class="page-width">
    <div class="saas-cta-container">
      <h2 class="saas-cta-heading">Empower your customers today.</h2>
      <p class="saas-cta-text">Install ESTS Delete Customer Account and give your Shopify customers the freedom to manage their own data — securely, transparently, and in one click.</p>
      <a href="https://apps.shopify.com/ests-delete-customer-1" class="button--cta">
        Install Free on Shopify <span>→</span>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SaaS CTA Section",
  "tag": "section",
  "class": "section",
  "presets": [
    {
      "name": "SaaS CTA Section"
    }
  ]
}
{% endschema %}
